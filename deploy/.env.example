# Domain and ports
APP_DOMAIN=example.com
NEXT_PUBLIC_SITE_URL=https://example.com
HTTP_PORT=80
HTTPS_PORT=443

# Container image tags
WEB_IMAGE=ghcr.io/your-org/youtube-to-text-web
WEB_IMAGE_TAG=latest
WORKER_IMAGE=ghcr.io/your-org/youtube-to-text-worker
WORKER_IMAGE_TAG=latest

# Runtime commands
WORKER_COMMAND=python -m src.main

# App secrets and external services
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
SUPABASE_URL=

S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Monitoring
SENTRY_DSN_WEB=
SENTRY_DSN_WORKER=

# Smoke checks
SMOKE_BASE_URL=http://127.0.0.1
SMOKE_TARGETS="/ /health"
SMOKE_TIMEOUT_SECONDS=10

# Alerting
FAILED_JOBS_ALERT_THRESHOLD=20
SLACK_WEBHOOK_URL=

# YouTube Authentication (to bypass bot detection)
# Pass the content of the cookies file directly:
YOUTUBE_COOKIES_CONTENT=
# OR pass the path to the cookies file:
# YOUTUBE_COOKIES_FILE=/app/data/cookies.txt
